# ===========================================================================
# sci-tangle — environment template
# Copy to .env and fill in real values:  cp .env.example .env
# .env is git-ignored and must NEVER be committed.
# ===========================================================================

# --- Yandex AI Studio (LLM + embeddings) -----------------------------------
# API key issued in Yandex Cloud (format: AQVN...). Used by pipeline/extract
# and backend embeddings/synthesis.
YANDEX_API_KEY=AQVN_your_api_key_here
# Yandex Cloud folder id that the key belongs to.
YANDEX_FOLDER_ID=b1g_your_folder_id_here

# --- OCR service (docling GPU endpoint) ------------------------------------
# pdf-ocr-api base URL used by the ingest OCR fallback (A-ocr).
OCR_API_URL=http://ithse.ru:1170

# --- Neo4j -----------------------------------------------------------------
# In containers the API reaches Neo4j via the compose service name (bolt://neo4j:7687);
# for local host tools use bolt://localhost:7687.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# Change this for any real/public deployment.
NEO4J_PASSWORD=knowledge-graph-2026

# --- Elasticsearch ---------------------------------------------------------
# In containers: http://es:9200 ; local host tools: http://localhost:9200.
ES_URL=http://localhost:9200

# --- Networking ------------------------------------------------------------
# Russian proxy for reaching RF resources when deploying/running from abroad.
# Format: http://user:pass@host:port  (leave empty to disable).
RU_PROXY=

# --- Frontend (build-time) -------------------------------------------------
# Public origin the browser uses to reach the API. The edge nginx proxies
# /api to the api service, so set this to the site's public URL.
#   local dev:        http://localhost:8000
#   prod (same host): http://your-server-ip   or   https://your-domain
# NOTE: this is baked into the bundle at build time (docker build of the UI).
VITE_API_URL=http://localhost:8000

# --- Deployment ------------------------------------------------------------
# Host port the edge nginx binds to (map 80 for HTTP; use a TLS front for 443).
HTTP_PORT=80
