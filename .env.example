# ===========================================================================
# sci-tangle — environment template
# Copy to .env and fill in real values:  cp .env.example .env
# .env is git-ignored and must NEVER be committed.
# ===========================================================================

# ===========================================================================
# LLM providers — подключение ЛЮБОЙ модели сменой конфига (shared/llm_gateway.py)
# ===========================================================================
# Глобальный провайдер по умолчанию для completion (planner/synthesis/summaries/
# extraction). Значения: yandex | mock | openrouter | openai | vllm | ollama |
# lmstudio | deepseek | groq | together | <любой openai-совместимый>.
#   yandex — текущее поведение (байт-в-байт как раньше); mock — dev/тесты без ключей.
LLM_PROVIDER=yandex
#
# Пер-роль оверрайды (формат "provider:model_id"). Если задан — перекрывает
# LLM_PROVIDER для конкретной роли. Пусто = использовать LLM_PROVIDER.
#   пример OpenRouter:  LLM_MODEL_SYNTHESIS=openrouter:deepseek/deepseek-chat-v3
#   пример Yandex:      LLM_MODEL_EXTRACTION=yandex:yandexgpt-lite
LLM_MODEL_PLANNER=
LLM_MODEL_SYNTHESIS=
LLM_MODEL_EXTRACTION=
LLM_MODEL_SUMMARIES=
#
# Опциональная фолбэк-цепочка (если primary упал/недоступен): "provider:model_id".
# Общий LLM_FALLBACK и/или пер-роль LLM_FALLBACK_SYNTHESIS и т.п.
LLM_FALLBACK=
#
# --- OpenRouter (когда придёт ключ — включается за 30 секунд) ----------------
# 1) LLM_PROVIDER=openrouter  (или пер-роль LLM_MODEL_*=openrouter:<model>)
# 2) OPENROUTER_API_KEY=sk-or-...   3) готово. base_url уже с дефолтом.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3
# structured output: auto (пробуем native json_schema → фолбэк json_object) |
# native | json_object | none
OPENROUTER_JSON_SCHEMA=auto
OPENROUTER_MAX_CONCURRENCY=4
OPENROUTER_TIMEOUT=90
#
# --- Другие openai-совместимые (примеры; раскомментируйте нужное) ------------
# OpenAI:      OPENAI_API_KEY=sk-...        OPENAI_MODEL=gpt-4o-mini
# Локальный vLLM/Ollama/LM Studio (ключ не нужен):
#   VLLM_BASE_URL=http://localhost:8001/v1  VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct  VLLM_REQUIRE_KEY=0
#   OLLAMA_MODEL=llama3.1                    (OLLAMA_BASE_URL дефолт localhost:11434/v1)
#
# --- Yandex AI Studio (LLM completion + embeddings) -------------------------
# API key issued in Yandex Cloud (format: AQVN...). Used for the yandex provider
# and for embeddings (embeddings всегда через Yandex, вне мультипровайдерного шлюза).
YANDEX_API_KEY=AQVN_your_api_key_here
# Yandex Cloud folder id that the key belongs to.
YANDEX_FOLDER_ID=b1g_your_folder_id_here

# ===========================================================================
# Эмбеддинг-пространства — подключение ЛЮБОЙ эмбеддинг-модели сменой конфига
# (shared/embeddings_gateway.py). Пространство = {provider, model, dim, prefix,
# normalized, query_kind}. Реестр в embeddings_gateway.py::SPACES.
# ===========================================================================
# Активное пространство для векторной ветки retrieval + прекомпьюта.
#   yandex-256  — исходное Yandex text-search-doc (256-dim). Дефолт (ничего не ломает).
#   qwen3-0.6b  — локальная Qwen/Qwen3-Embedding-0.6B (1024-dim, 32K контекст).
#   hash-256    — dev-фолбэк (детерминированный хеш; НИКОГДА не мешать с real).
EMBEDDING_SPACE=yandex-256
#
# URL локального GPU/CPU эмбеддинг-сервиса (deploy/embed_service, порт 1171).
#   на сервере/через SSH-туннель:  http://127.0.0.1:1171
#   (порт 1171 наружу НЕ открыт — для пересчёта с ноутбука подними туннель:
#    ssh -p 1122 -N -L 1171:127.0.0.1:1171 hromov@ithse.ru )
EMBED_LOCAL_URL=http://127.0.0.1:1171
#
# Пороги семантического гейта задаются пер-пространство в retrieval.py::_SPACE_GATES;
# при перекалибровке под новое пространство можно переопределить через env:
# SEM_THRESHOLD=  SEM_STRONG=  SEM_CONCEPT=

# --- OCR service (docling GPU endpoint) ------------------------------------
# pdf-ocr-api base URL used by the ingest OCR fallback (A-ocr).
OCR_API_URL=http://ithse.ru:1170

# --- Neo4j -----------------------------------------------------------------
# In containers the API reaches Neo4j via the compose service name (bolt://neo4j:7687);
# for local host tools use bolt://localhost:7687.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# Change this for any real/public deployment.
NEO4J_PASSWORD=knowledge-graph-2026

# --- Elasticsearch ---------------------------------------------------------
# In containers: http://es:9200 ; local host tools: http://localhost:9200.
ES_URL=http://localhost:9200

# --- Networking ------------------------------------------------------------
# Russian proxy for reaching RF resources when deploying/running from abroad.
# Format: http://user:pass@host:port  (leave empty to disable).
RU_PROXY=

# --- Frontend (build-time) -------------------------------------------------
# Public origin the browser uses to reach the API. The edge nginx proxies
# /api to the api service, so set this to the site's public URL.
#   local dev:        http://localhost:8000
#   prod (same host): http://your-server-ip   or   https://your-domain
# NOTE: this is baked into the bundle at build time (docker build of the UI).
VITE_API_URL=http://localhost:8000

# --- Deployment ------------------------------------------------------------
# Host port the edge nginx binds to (map 80 for HTTP; use a TLS front for 443).
HTTP_PORT=80
