# ---------------------------------------------------------------------------
# sci-tangle — UI image (Vite/React build served by nginx)
# Build context: repository root.
# ---------------------------------------------------------------------------

# ---- stage 1: build -------------------------------------------------------
FROM node:20-alpine AS build

WORKDIR /app

# VITE_API_URL is a build-time variable baked into the bundle.
# In the compose stack this is the public origin (nginx reverse-proxies /api).
ARG VITE_API_URL=""
ENV VITE_API_URL=${VITE_API_URL}

COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

COPY frontend/ ./
RUN npm run build

# ---- stage 2: serve -------------------------------------------------------
FROM nginx:alpine AS serve

# SPA-aware nginx config for the static bundle (client-side routing fallback).
COPY deploy/nginx.ui.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=5 \
    CMD wget -qO- http://localhost:80/ >/dev/null 2>&1 || exit 1
