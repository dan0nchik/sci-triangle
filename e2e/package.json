{
  "name": "sci-tangle-e2e",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright E2E suite for sci-tangle frontend (mock + live projects)",
  "type": "module",
  "scripts": {
    "e2e": "playwright test",
    "e2e:mock": "playwright test --project=mock",
    "e2e:live": "cross-env E2E_REQUIRE_BACKEND=1 playwright test --project=live",
    "e2e:report": "playwright show-report",
    "install:browser": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "cross-env": "^7.0.3"
  }
}
